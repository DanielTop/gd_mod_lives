{
    "geode": "5.3.0",
    "gd": {
        "mac": "2.2081",
        "win": "2.2081"
    },
    "id": "larry.100lives",
    "name": "100 Lives",
    "version": "v1.3.0",
    "developer": "larry",
    "description": "Extra lives, game mode cycling, and rescue checkpoint system for Geometry Dash.",
    "settings": {
        "lives-count": {
            "name": "Number of Lives",
            "description": "How many lives you get per attempt",
            "type": "int",
            "default": 100,
            "min": 2,
            "max": 9999
        },
        "invincibility-time": {
            "name": "Invincibility Time",
            "description": "Seconds of invincibility after each hit",
            "type": "float",
            "default": 1.2,
            "min": 0.3,
            "max": 5.0
        },
        "protection-mode": {
            "name": "Protection Mode",
            "description": "What lives protect you from",
            "type": "string",
            "default": "all",
            "one-of": ["all", "hazards-only"],
            "enum-names": {
                "all": "All obstacles",
                "hazards-only": "Spikes & saws only"
            }
        },
        "checkpoint-interval": {
            "name": "Checkpoint Interval",
            "description": "How often to save rescue checkpoint (seconds)",
            "type": "float",
            "default": 0.5,
            "min": 0.1,
            "max": 10.0
        },
        "mode-cube": {
            "name": "Cube in cycle",
            "type": "bool",
            "default": true
        },
        "mode-ship": {
            "name": "Ship in cycle",
            "type": "bool",
            "default": true
        },
        "mode-ball": {
            "name": "Ball in cycle",
            "type": "bool",
            "default": false
        },
        "mode-ufo": {
            "name": "UFO in cycle",
            "type": "bool",
            "default": true
        },
        "mode-wave": {
            "name": "Wave in cycle",
            "type": "bool",
            "default": true
        },
        "mode-robot": {
            "name": "Robot in cycle",
            "type": "bool",
            "default": false
        },
        "mode-spider": {
            "name": "Spider in cycle",
            "type": "bool",
            "default": false
        },
        "mode-swing": {
            "name": "Swing in cycle",
            "type": "bool",
            "default": true
        },
        "rescue-key": {
            "name": "Rescue Key",
            "description": "Load last safe checkpoint",
            "type": "keybind",
            "default": "B"
        },
        "fly-toggle-key": {
            "name": "Cycle Game Mode",
            "description": "Cycle through enabled game modes",
            "type": "keybind",
            "default": "M"
        }
    },
    "repository": "https://github.com/DanielTop/gd_mod_lives"
}
